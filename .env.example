# =============================================================
# D&D Meta Game - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# Only PORT is required. Everything else has sensible defaults.

# Server port (default: 3000)
PORT=3000

# =============================================================
# AI Provider: Claude (cloud, recommended)
# =============================================================
# Get your API key from https://console.anthropic.com
# When set, Claude is the primary AI provider.
# Opus handles all world building/generation; Sonnet handles DM sessions.
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================
# AI Provider: Ollama (local, offline fallback)
# =============================================================
# Ollama is used automatically when ANTHROPIC_API_KEY is not set.
# Install from https://ollama.com, then: ollama pull gpt-oss:20b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:20b

# =============================================================
# Database Configuration
# =============================================================
# By default, uses a local SQLite file (local.db) in the project root.
# No configuration needed for local development.
#
# For cloud sync across devices, configure Turso:
# Get credentials from https://turso.tech after creating a database.
# Then run: npm run migrate-to-cloud
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# =============================================================
# Authentication
# =============================================================
# JWT secret for signing auth tokens.
# If not set, a random secret is auto-generated and stored in the database.
# Only set this if you want to share tokens across multiple server instances.
# JWT_SECRET=your-secret-key
